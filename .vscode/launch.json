{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Northwind.Api",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/Northwind.Api/src/Northwind.Api/Northwind.Api.csproj"
    },
    {
      "name": "Northwind.Web",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/Northwind.Web",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Northwind.Api", "Northwind.Web"],
      "stopAll": true
    }
  ]
}
