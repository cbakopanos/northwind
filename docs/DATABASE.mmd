        string quantity_per_unit
        numeric unit_price
        smallint units_in_stock
        smallint units_on_order
        smallint reorder_level
        bool is_discontinued
    }

    CRM_CUSTOMERS["[crm] customers"] {
        string customer_id PK
        string company_name
        string contact_name
        string contact_title
        string address
        string city
        string region
        string postal_code
        string country
        string phone
        string fax
        text homepage_url
    }