    PURCHASING_SUPPLIERS["[purchasing] suppliers"] {
        int supplier_id PK
        string company_name
        string contact_name
        string contact_title
        string address
        string city
        string region
        string postal_code
        string country
        string phone
        string fax
        text homepage_url
    }

    CATALOG_CATEGORIES["[catalog] categories"] {
        int category_id PK
        string category_name
        text description
        bytes picture
    }

    CATALOG_PRODUCTS["[catalog] products"] {
