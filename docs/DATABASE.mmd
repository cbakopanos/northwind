erDiagram
    direction LR

    EMPLOYEES o|--o{ EMPLOYEES : manages
    CUSTOMERS o|--o{ ORDERS : places
    EMPLOYEES o|--o{ ORDERS : handles
    SHIPPERS o|--o{ ORDERS : ships_via

    CATEGORIES o|--o{ PRODUCTS : groups
    SUPPLIERS o|--o{ PRODUCTS : supplies

    ORDERS ||--o{ ORDER_DETAILS : contains
    PRODUCTS ||--o{ ORDER_DETAILS : appears_in

    CUSTOMERS ||--o{ CUSTOMER_CUSTOMER_DEMO : has
    CUSTOMER_DEMOGRAPHICS ||--o{ CUSTOMER_CUSTOMER_DEMO : classifies

    REGION ||--o{ TERRITORIES : contains
    EMPLOYEES ||--o{ EMPLOYEE_TERRITORIES : assigned_to
    TERRITORIES ||--o{ EMPLOYEE_TERRITORIES : includes

    EMPLOYEES {
        int EmployeeID PK
        string LastName
        string FirstName
        int ReportsTo FK
    }

    CATEGORIES {
        int CategoryID PK
        string CategoryName
    }

    CUSTOMERS {
        string CustomerID PK
        string CompanyName
    }

    SHIPPERS {
        int ShipperID PK
        string CompanyName
    }

    SUPPLIERS {
        int SupplierID PK
        string CompanyName
    }

    PRODUCTS {
        int ProductID PK
        string ProductName
        int SupplierID FK
        int CategoryID FK
        numeric UnitPrice
        bool Discontinued
    }

    ORDERS {
        int OrderID PK
        string CustomerID FK
        int EmployeeID FK
        int ShipVia FK
        datetime OrderDate
        datetime ShippedDate
    }

    ORDER_DETAILS {
        int OrderID PK, FK
        int ProductID PK, FK
        numeric UnitPrice
        int Quantity
        float Discount
    }

    CUSTOMER_DEMOGRAPHICS {
        string CustomerTypeID PK
    }

    CUSTOMER_CUSTOMER_DEMO {
        string CustomerID PK, FK
        string CustomerTypeID PK, FK
    }

    REGION {
        int RegionID PK
        string RegionDescription
    }

    TERRITORIES {
        string TerritoryID PK
        int RegionID FK
        string TerritoryDescription
    }

    EMPLOYEE_TERRITORIES {
        int EmployeeID PK, FK
        string TerritoryID PK, FK
    }